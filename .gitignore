# Raw book-plate exports (~107MB) are regenerable from the source PDF via:
#   pdftoppm -png -r 200 "~/Downloads/2026_01_The Magic Tree_INT.pdf" public/scenes/raw/page
# Keep only page-09 (used by the Phase 0 spike); processed plates land elsewhere.
/public/scenes/raw/*
!/public/scenes/raw/page-09.png

# Intermediate crops (pre-outpaint / pre-cutout) — regenerable from raw via
# scripts/crop.mjs. The irreplaceable AI outputs (outpainted + text-cleaned
# masters, sprites, web textures, video loops) ARE committed.
/public/scenes/crops/
/public/characters/raw/
